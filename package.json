{
  "name": "rn-livescore",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "sync:config": "node scripts/sync-env-config.mjs",
    "build:apk": "eas build --platform android --profile preview",
    "build:aab": "eas build --platform android --profile production",
    "store:assets": "node scripts/generate-store-assets.mjs",
    "store:assets:vi": "GOOGLE_PLAY_LANGUAGE=vi-VN node scripts/generate-store-assets.mjs",
    "store:extras:en": "node scripts/gen-extra-store-images.cjs",
    "store:extras:vi": "node scripts/gen-extra-store-images-vi.cjs",
    "store:images:all": "npm run store:assets && npm run store:assets:vi && npm run store:extras:en && npm run store:extras:vi",
    "store:listing": "node scripts/generate-store-listing.mjs",
    "store:prepare": "npm run store:assets && npm run store:listing",
    "play:upload-listing": "node --env-file=.env scripts/upload-play-listing.mjs",
    "submit:play": "eas submit --platform android --profile production --latest",
    "release:auto": "bash scripts/release-android.sh",
    "release:production": "bash scripts/release-production.sh",
    "release:apk": "bash scripts/build-release-apk.sh",
    "release:ios": "bash scripts/build-ios.sh",
    "android:keygen": "bash scripts/gen-android-keystore.sh",
    "deps:install:all": "npm install && npx expo install expo-asset expo-constants expo-device expo-notifications @react-native-async-storage/async-storage @expo/metro-runtime react-native-safe-area-context react-native-screens react-native-webview",
    "bump:version": "node scripts/bump-app-version.mjs",
    "ios": "expo run:ios",
    "build:local:android": "bash scripts/build-local-android.sh"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.10",
    "expo": "~53.0.0",
    "expo-asset": "~11.1.7",
    "expo-constants": "~17.1.8",
    "expo-device": "~7.1.4",
    "expo-notifications": "~0.31.5",
    "expo-status-bar": "~2.2.3",
    "fast-xml-parser": "^5.2.5",
    "googleapis": "^150.0.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-web": "^0.20.0",
    "react-native-webview": "13.13.5"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "eas-cli": "^16.12.0",
    "sharp": "^0.34.1",
    "typescript": "~5.8.3"
  }
}
